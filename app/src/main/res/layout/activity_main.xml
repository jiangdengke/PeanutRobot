<?xml version="1.0" encoding="utf-8"?>
<layout>
<data>

</data>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/grey_100"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_vertical_split"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.3" />

    <FrameLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
    </FrameLayout>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/ll_left"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintEnd_toStartOf="@+id/guideline_vertical_split"
        app:layout_constraintBottom_toTopOf="@+id/ll_bottom_actions"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:orientation="vertical"
        android:gravity="top"
        >
        <com.jiangdg.ausbc.widget.AspectRatioTextureView
            android:id="@+id/texture_view_1"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            />

        <com.jiangdg.ausbc.widget.AspectRatioTextureView
            android:id="@+id/texture_view_2"
            android:layout_width="0dp"
            android:visibility="gone"
            android:layout_height="match_parent"
            android:layout_weight="1"
            />

        <com.jiangdg.ausbc.widget.AspectRatioTextureView
            android:id="@+id/texture_view_3"
            android:layout_width="0dp"
            android:visibility="gone"
            android:layout_height="match_parent"
            android:layout_weight="1"
            />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_vertical_point"
            android:layout_width="180dp"
            android:layout_height="330dp"

           />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_show_room_map"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:background="@drawable/text_view_selector"
            android:gravity="center"
            android:padding="15dp"
            android:text="展示图片"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

    </androidx.appcompat.widget.LinearLayoutCompat>



    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_point"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toEndOf="@+id/guideline_vertical_split"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/ll_bottom_actions"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/tv_point_empty"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:text="未获取到点位"
        android:textColor="@color/grey_700"
        android:textSize="28sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/ll_bottom_actions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/guideline_vertical_split"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/ll_bottom_actions"
        android:layout_width="0dp"
        android:orientation="vertical"
        app:layout_constraintStart_toEndOf="@+id/guideline_vertical_split"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_secondary_screen_display"
                android:padding="15dp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="副屏显示"
                android:textColor="@color/black"
                android:gravity="center"
                android:textStyle="bold"
                android:textSize="25sp"
                android:background="@color/grey_500"
                android:layout_margin="10dp" />

            <TextView
                android:id="@+id/tv_refresh_points"
                android:padding="15dp"
                android:textStyle="bold"
                android:textSize="25sp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_margin="10dp"
                android:layout_height="wrap_content"
                android:background="@drawable/text_view_selector"
                android:text="刷新点位"
                android:textColor="@color/white"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_navigate"
                android:padding="15dp"
                android:textStyle="bold"
                android:textSize="25sp"
                android:layout_weight="1.2"
                android:layout_width="0dp"
                android:layout_margin="10dp"
                android:layout_height="wrap_content"
                android:background="@drawable/text_view_selector"
                android:text="立即出发"
                android:textColor="@color/white"
                android:gravity="center" />
        </androidx.appcompat.widget.LinearLayoutCompat>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_go_charge"
                android:padding="15dp"
                android:textStyle="bold"
                android:textSize="25sp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_margin="10dp"
                android:layout_height="wrap_content"
                android:background="@drawable/text_view_selector"
                android:text="回充"
                android:textColor="@color/white"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_patrol_warehouse"
                android:padding="15dp"
                android:textStyle="bold"
                android:textSize="25sp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_margin="10dp"
                android:layout_height="wrap_content"
                android:background="@drawable/text_view_selector"
                android:text="巡仓"
                android:textColor="@color/white"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_recall"
                android:padding="15dp"
                android:textStyle="bold"
                android:textSize="25sp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_margin="10dp"
                android:layout_height="wrap_content"
                android:background="@drawable/text_view_selector"
                android:text="召回"
                android:textColor="@color/white"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_idle_screen_lock"
                android:padding="15dp"
                android:textStyle="bold"
                android:textSize="25sp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_margin="10dp"
                android:layout_height="wrap_content"
                android:background="@drawable/text_view_selector"
                android:text="立即锁屏"
                android:textColor="@color/white"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_idle_screen_settings"
                android:padding="15dp"
                android:textStyle="bold"
                android:textSize="25sp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_margin="10dp"
                android:layout_height="wrap_content"
                android:background="@drawable/text_view_selector"
                android:text="锁屏设置"
                android:textColor="@color/white"
                android:gravity="center" />
        </androidx.appcompat.widget.LinearLayoutCompat>

        <TextView
            android:id="@+id/tv_warehouse_task_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="8dp"
            android:gravity="center"
            android:minHeight="32dp"
            android:text=""
            android:textColor="@color/grey_700"
            android:textSize="18sp"
            android:textStyle="bold" />
    </androidx.appcompat.widget.LinearLayoutCompat>

    <FrameLayout
        android:id="@+id/fl_room_map_preview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_room_map"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="48dp"
            android:background="@color/white"
            android:contentDescription="房间点位对照图"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/tv_room_map_close"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="top|end"
            android:layout_margin="24dp"
            android:background="#99000000"
            android:gravity="center"
            android:text="X"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/fl_idle_lock"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/black"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_idle_screen"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/black"
            android:contentDescription="屏保图片"
            android:src="@mipmap/ic_launcher" />

        <TextView
            android:id="@+id/tv_idle_unlock_hint"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="48dp"
            android:background="#99000000"
            android:paddingLeft="36dp"
            android:paddingTop="18dp"
            android:paddingRight="36dp"
            android:paddingBottom="18dp"
            android:text="点击输入密码"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
</layout>
